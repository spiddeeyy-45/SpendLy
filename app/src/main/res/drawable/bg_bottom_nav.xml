<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item>
        <shape android:shape="rectangle">
            <corners android:radius="32dp" />
            <solid android:color="#B3100E1C" />
        </shape>
    </item>
    <item
        android:top="0dp"
        android:left="0dp"
        android:right="0dp"
        android:bottom="0dp">
        <shape android:shape="rectangle">
            <corners android:radius="32dp" />
            <stroke
                android:width="1dp"
                android:color="#28FFFFFF" />
        </shape>
    </item>
    <item
        android:top="1dp"
        android:left="1dp"
        android:right="1dp"
        android:bottom="1dp">
        <shape android:shape="rectangle">
            <corners android:radius="31dp" />
            <stroke
                android:width="1dp"
                android:color="#3D5B6EF5" />
        </shape>
    </item>

</layer-list>