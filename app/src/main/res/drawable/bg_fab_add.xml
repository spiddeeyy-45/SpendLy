<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">


    <item>
        <shape android:shape="rectangle">
            <corners android:radius="20dp" />
            <solid android:color="#6C5FF5" />
        </shape>
    </item>


    <item>
        <shape android:shape="rectangle">
            <corners android:radius="20dp" />
            <stroke
                android:width="1.5dp"
                android:color="#35FFFFFF" />
        </shape>
    </item>

    <item
        android:top="1dp"
        android:left="1dp"
        android:right="1dp"
        android:bottom="1dp">
        <shape android:shape="rectangle">
            <corners android:radius="19dp" />
            <stroke
                android:width="1dp"
                android:color="#55A78BFA" />
        </shape>
    </item>

</layer-list>