<?xml version="1.0" encoding="utf-8"?>
<layout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    tools:context="UI.addVehicle">
<FrameLayout
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#07071A">

    <!-- BG ORB 1 -->
    <View
        android:layout_width="280dp"
        android:layout_height="280dp"
        android:background="@drawable/bg_glow_orb_purp"
        android:alpha="0.4"
        android:layout_marginStart="-70dp"
        android:layout_marginTop="-60dp"/>

    <!-- BG ORB 2 -->
    <View
        android:layout_width="180dp"
        android:layout_height="180dp"
        android:background="@drawable/bg_glow_orb_blue"
        android:alpha="0.22"
        android:layout_gravity="end"
        android:layout_marginEnd="-40dp"
        android:layout_marginTop="200dp"/>

    <!-- BG ORB 3 -->
    <View
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:background="@drawable/bg_glow_orb_purp"
        android:alpha="0.2"
        android:layout_gravity="bottom|start"
        android:layout_marginBottom="80dp"
        android:layout_marginStart="10dp"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:scrollbars="none"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="56dp"
            android:paddingBottom="40dp">

            <!-- ══ STEP DOTS ══ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="28dp">


                <!-- Active dot (wider) -->
                <View
                    android:id="@+id/dot1"
                    android:layout_width="20dp"
                    android:layout_height="6dp"
                    android:background="@drawable/bg_step_dot_active"
                    android:layout_marginEnd="6dp"/>

                <View
                    android:id="@+id/dot2"
                    android:layout_width="6dp"
                    android:layout_height="6dp"
                    android:background="@drawable/bg_step_dot_inactive"/>

            </LinearLayout>

            <!-- ══ TITLE ══ -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Add your vehicle"
                android:textColor="#EEF0FF"
                android:textSize="24sp"
                android:textStyle="bold"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="You can always add more later"
                android:textColor="#60B4B9DC"
                android:textSize="12sp"
                android:layout_marginBottom="20dp"/>

            <!-- ══ VEHICLE TYPE SELECTOR ══ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <!-- BIKE -->
                <LinearLayout
                    android:id="@+id/btnSelectBike"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:paddingTop="16dp"
                    android:paddingBottom="16dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_vehicle_type_selected"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:id="@+id/ivBikeIcon"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_bike"
                        android:layout_marginBottom="8dp"/>

                    <TextView
                        android:id="@+id/tvBikeLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Bike"
                        android:textColor="#A99DFF"
                        android:textSize="13sp"
                        android:textStyle="bold"/>

                </LinearLayout>

                <!-- CAR -->
                <LinearLayout
                    android:id="@+id/btnSelectCar"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:paddingTop="16dp"
                    android:paddingBottom="16dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_vehicle_default"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:id="@+id/ivCarIcon"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_car"
                        android:layout_marginBottom="8dp"/>

                    <TextView
                        android:id="@+id/tvCarLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Car"
                        android:textColor="#80B4B9DC"
                        android:textSize="13sp"
                        android:textStyle="bold"/>

                </LinearLayout>

            </LinearLayout>

            <!-- ══ VEHICLE DETAILS CARD ══ -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardVehicleDetails"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="22dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@android:color/transparent">

                <eightbitlab.com.blurview.BlurView
                    android:id="@+id/blurAddVehicle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="22dp"
                        android:background="@drawable/bg_glass_card">

                        <!-- Shimmer line -->
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="@drawable/bg_shimmer_line"
                            android:layout_marginBottom="18dp"/>

                        <!-- Company / Brand -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="COMPANY / BRAND"
                            android:textColor="#60B4B9DC"
                            android:textSize="10sp"
                            android:textAllCaps="true"
                            android:letterSpacing="0.05"
                            android:layout_marginBottom="6dp"/>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingStart="14dp"
                            android:paddingEnd="14dp"
                            android:background="@drawable/bg_input_field"
                            android:layout_marginBottom="14dp">


                            <EditText
                                android:id="@+id/etCompany"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@android:color/transparent"
                                android:hint="e.g. Hero, Honda, Bajaj"
                                android:textColor="#EEF0FF"
                                android:textSize="13sp"
                                android:inputType="textCapWords"
                                android:singleLine="true"
                                android:imeOptions="actionNext"/>

                        </LinearLayout>

                        <!-- Model Name -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="MODEL NAME"
                            android:textColor="#60B4B9DC"
                            android:textSize="10sp"
                            android:textAllCaps="true"
                            android:letterSpacing="0.05"
                            android:layout_marginBottom="6dp"/>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingStart="14dp"
                            android:paddingEnd="14dp"
                            android:background="@drawable/bg_input_field"
                            android:layout_marginBottom="14dp">

                            <EditText
                                android:id="@+id/etModel"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@android:color/transparent"
                                android:hint="e.g. Splendor, Activa, Swift"
                                android:textColor="#EEF0FF"
                                android:textSize="13sp"
                                android:inputType="textCapWords"
                                android:singleLine="true"
                                android:imeOptions="actionNext"/>

                        </LinearLayout>

                        <!-- Number Plate -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="NUMBER PLATE"
                            android:textColor="#60B4B9DC"
                            android:textSize="10sp"
                            android:textAllCaps="true"
                            android:letterSpacing="0.05"
                            android:layout_marginBottom="6dp"/>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingStart="14dp"
                            android:paddingEnd="14dp"
                            android:background="@drawable/bg_input_field"
                            android:layout_marginBottom="14dp">

                            <EditText
                                android:id="@+id/etNumberPlate"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@android:color/transparent"
                                android:hint="MH 02 AB 1234"
                                android:textColor="#EEF0FF"
                                android:textSize="13sp"
                                android:inputType="textCapCharacters"
                                android:singleLine="true"
                                android:imeOptions="actionNext"/>

                        </LinearLayout>

                        <!-- Year -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="YEAR"
                            android:textColor="#60B4B9DC"
                            android:textSize="10sp"
                            android:textAllCaps="true"
                            android:letterSpacing="0.05"
                            android:layout_marginBottom="6dp"/>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingStart="14dp"
                            android:paddingEnd="14dp"
                            android:background="@drawable/bg_input_field"
                            android:layout_marginBottom="22dp">

                            <EditText
                                android:id="@+id/etYear"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@android:color/transparent"
                                android:hint="e.g. 2022"
                                android:textColor="#EEF0FF"
                                android:textSize="13sp"
                                android:inputType="number"
                                android:maxLength="4"
                                android:singleLine="true"
                                android:imeOptions="actionDone"/>

                        </LinearLayout>

                        <!-- Add Vehicle Button -->
                        <TextView
                            android:id="@+id/btnAddVehicle"
                            android:layout_width="match_parent"
                            android:layout_height="50dp"
                            android:gravity="center"
                            android:text="Add Vehicle &amp; Continue"
                            android:textColor="#FFFFFF"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:background="@drawable/bg_btn_primary"
                            android:clickable="true"
                            android:focusable="true"/>
                        <TextView
                            android:id="@+id/tvAddVehicleError"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text=""
                            android:textColor="#FF8A8A"
                            android:textSize="12sp"
                            android:gravity="center"
                            android:layout_marginTop="10dp"
                            android:visibility="gone"/>

                    </LinearLayout>

                </eightbitlab.com.blurview.BlurView>

            </androidx.cardview.widget.CardView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginTop="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="or  "
                    android:textColor="#40B4B9DC"
                    android:textSize="13sp"/>

                <TextView
                    android:id="@+id/tvSkip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Skip for now →"
                    android:textColor="#A99DFF"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:clickable="true"
                    android:focusable="true"/>

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

</FrameLayout>
</layout>