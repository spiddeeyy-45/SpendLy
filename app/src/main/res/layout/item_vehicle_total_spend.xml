<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="0dp"
    android:layout_height="wrap_content"
    android:layout_weight="1"
    android:orientation="vertical"
    android:padding="5dp">

    <LinearLayout
        android:id="@+id/statCardRoot"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp"
        android:background="@drawable/bg_stats_card">

        <!-- Stat label -->
        <TextView
            android:id="@+id/tvStatLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TOTAL SPEND"
            android:textColor="#80B4B9DC"
            android:textSize="10sp"
            android:textAllCaps="true"
            android:letterSpacing="0.05"
            android:fontFamily="sans-serif"
            android:layout_marginBottom="6dp"/>

        <!-- Stat value -->
        <TextView
            android:id="@+id/tvStatValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="₹11,340"
            android:textColor="#EEF0FF"
            android:textSize="22sp"
            android:textStyle="bold"
            android:fontFamily="@font/syne_bold"
            android:lineSpacingExtra="-2dp"/>
        <TextView
            android:id="@+id/tvStatTrend"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="↑ 12% vs last month"
            android:textColor="#5DE8B8"
            android:textSize="10sp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="2dp"
            android:paddingBottom="2dp"
            android:background="@drawable/bg_pill_up"
            android:fontFamily="sans-serif-medium"/>

    </LinearLayout>

</LinearLayout>