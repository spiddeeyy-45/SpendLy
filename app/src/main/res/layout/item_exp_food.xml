<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="0dp"
    android:layout_height="wrap_content"
    android:layout_weight="1"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="6dp"
    android:id="@+id/expenseCardRoot"
    android:clickable="true"
    android:focusable="true">
    <LinearLayout

        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingTop="13dp"
        android:paddingBottom="13dp"
        android:background="@drawable/bg_expense_item"
        android:foreground="?attr/selectableItemBackgroundBorderless">

        <FrameLayout
            android:id="@+id/ivExpenseIconBg"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_expense_icon_fuel">

            <ImageView
                android:id="@+id/ivExpenseIcon"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_food" />

        </FrameLayout>

        <TextView
            android:id="@+id/tvExpenseLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="7dp"
            android:text="Food"
            android:textColor="#A6B4B9DC"
            android:textSize="10sp"
            android:textAlignment="center"
            android:fontFamily="sans-serif-medium"/>

    </LinearLayout>

</LinearLayout>