<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="200dp"
    android:layout_height="wrap_content"
    android:layout_marginEnd="14dp">

    <!-- Blur glass layer -->
    <eightbitlab.com.blurview.BlurView
        android:id="@+id/blurVehicleCard"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:blurOverlayColor="#1AFFFFFF">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:background="@drawable/bg_vehicle_default">

            <!-- Badge (Primary / Active) -->
            <TextView
                android:id="@+id/tvVehicleBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Primary"
                android:textColor="#A99DFF"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textAllCaps="true"
                android:letterSpacing="0.05"
                android:paddingStart="9dp"
                android:paddingEnd="9dp"
                android:paddingTop="3dp"
                android:paddingBottom="3dp"
                android:background="@drawable/bg_badge_purple"
                android:layout_marginBottom="10dp"/>

            <!-- Vehicle Name -->
            <TextView
                android:id="@+id/tvVehicleName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Honda City"
                android:textColor="#EEF0FF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:fontFamily="@font/syne_bold"
                android:layout_marginBottom="2dp"/>

            <!-- Plate Number -->
            <TextView
                android:id="@+id/tvVehiclePlate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MH 01 AB 1234"
                android:textColor="#80B4B9DC"
                android:textSize="11sp"
                android:layout_marginBottom="10dp"/>

            <!-- Amount -->
            <TextView
                android:id="@+id/tvVehicleAmount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="₹8,240"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold"
                android:fontFamily="@font/syne_bold"/>

            <TextView
                android:id="@+id/tvVehicleAmountLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="this month"
                android:textColor="#60B4B9DC"
                android:textSize="10sp"
                android:layout_marginTop="1dp"/>

            <TextView
                android:id="@+id/tvVehicleEmoji"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🚗"
                android:textSize="34sp"
                android:alpha="0.15"
                android:layout_gravity="end"
                android:layout_marginTop="-30dp"/>

        </LinearLayout>

    </eightbitlab.com.blurview.BlurView>

</FrameLayout>