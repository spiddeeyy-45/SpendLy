<?xml version="1.0" encoding="utf-8"?>
<layout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    tools:context="UI.Login">


<FrameLayout
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#07071A">

    <!-- BG ORB 1 -->
    <View
        android:layout_width="280dp"
        android:layout_height="280dp"
        android:background="@drawable/bg_glow_orb_purp"
        android:alpha="0.4"
        android:layout_marginStart="-70dp"
        android:layout_marginTop="-60dp"/>

    <!-- BG ORB 2 -->
    <View
        android:layout_width="180dp"
        android:layout_height="180dp"
        android:background="@drawable/bg_glow_orb_blue"
        android:alpha="0.22"
        android:layout_gravity="end"
        android:layout_marginEnd="-40dp"
        android:layout_marginTop="200dp"/>

    <!-- BG ORB 3 -->
    <View
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:background="@drawable/bg_glow_orb_purp"
        android:alpha="0.2"
        android:layout_gravity="bottom|start"
        android:layout_marginBottom="80dp"
        android:layout_marginStart="10dp"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:scrollbars="none"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="60dp"
            android:paddingBottom="40dp">

            <!-- ══ APP LOGO ══ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginBottom="32dp">

                <ImageView
                    android:id="@+id/ivAppLogo"
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:background="@drawable/bg_logo_icon"
                    android:src="@mipmap/ic_launcher"
                    android:scaleType="centerInside"
                    android:padding="12dp"
                    android:layout_marginBottom="12dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SpendLy"
                    android:textColor="#EEF0FF"
                    android:textSize="24sp"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Track every rupee, every ride"
                    android:textColor="#60B4B9DC"
                    android:textSize="12sp"
                    android:layout_marginTop="3dp"/>

            </LinearLayout>

            <!-- ══ LOGIN CARD ══ -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardLogin"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="22dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@android:color/transparent">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="22dp"
                        android:background="@drawable/bg_glass_card">


                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Welcome back"
                            android:textColor="#EEF0FF"
                            android:textSize="18sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Sign in to continue"
                            android:textColor="#60B4B9DC"
                            android:textSize="12sp"
                            android:layout_marginBottom="20dp"/>

                        <!-- Email -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="EMAIL"
                            android:textColor="#60B4B9DC"
                            android:textSize="10sp"
                            android:textAllCaps="true"
                            android:letterSpacing="0.05"
                            android:layout_marginBottom="6dp"/>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingStart="14dp"
                            android:paddingEnd="14dp"
                            android:background="@drawable/bg_input_field"
                            android:layout_marginBottom="14dp">

                            <EditText
                                android:id="@+id/etEmail"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@android:color/transparent"
                                android:hint="your@email.com"
                                android:textColor="#EEF0FF"
                                android:textSize="13sp"
                                android:inputType="textEmailAddress"
                                android:singleLine="true"
                                android:imeOptions="actionNext"/>

                        </LinearLayout>

                        <!-- Password -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="PASSWORD"
                            android:textColor="#60B4B9DC"
                            android:textSize="10sp"
                            android:textAllCaps="true"
                            android:letterSpacing="0.05"
                            android:layout_marginBottom="6dp"/>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingStart="14dp"
                            android:paddingEnd="14dp"
                            android:background="@drawable/bg_input_field"
                            android:layout_marginBottom="8dp">

                            <EditText
                                android:id="@+id/etPassword"
                                android:layout_width="0dp"
                                android:layout_weight="1"
                                android:layout_height="match_parent"
                                android:background="@android:color/transparent"
                                android:hint="••••••••"
                                android:textColor="#EEF0FF"
                                android:textSize="13sp"
                                android:inputType="textPassword"
                                android:singleLine="true"
                                android:imeOptions="actionDone"/>

                            <TextView
                                android:id="@+id/tvShowPassword"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Show"
                                android:textColor="#A99DFF"
                                android:textSize="11sp"
                                android:clickable="true"
                                android:focusable="true"/>

                        </LinearLayout>

                        <!-- Forgot password -->
                        <TextView
                            android:id="@+id/tvForgotPassword"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="end"
                            android:text="Forgot password?"
                            android:textColor="#A99DFF"
                            android:textSize="11sp"
                            android:layout_marginBottom="20dp"
                            android:clickable="true"
                            android:focusable="true"/>

                        <!-- Sign In Button -->
                        <TextView
                            android:id="@+id/btnLogin"
                            android:layout_width="match_parent"
                            android:layout_height="50dp"
                            android:gravity="center"
                            android:text="Sign In"
                            android:textColor="#FFFFFF"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:background="@drawable/bg_btn_primary"
                            android:clickable="true"
                            android:focusable="true"/>

                        <!-- Error text -->
                        <TextView
                            android:id="@+id/tvLoginError"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text=""
                            android:textColor="#FF8A8A"
                            android:textSize="12sp"
                            android:gravity="center"
                            android:layout_marginTop="10dp"
                            android:visibility="gone"
                            tools:text="Invalid email or password"
                            tools:visibility="visible"/>

                    </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Register link -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginTop="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Don't have an account?  "
                    android:textColor="#60B4B9DC"
                    android:textSize="13sp"/>

                <TextView
                    android:id="@+id/tvGoToRegister"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Register"
                    android:textColor="#A99DFF"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:clickable="true"
                    android:focusable="true"/>

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

</FrameLayout>
</layout>