<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_bottom_sheet">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_dialog_glass"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="14dp"
                android:paddingBottom="32dp">
                <View
                    android:layout_width="40dp"
                    android:layout_height="4dp"
                    android:background="@drawable/bg_drag_handle"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginBottom="20dp"/>
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="28dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <FrameLayout
                            android:layout_width="42dp"
                            android:layout_height="42dp"
                            android:background="@drawable/bg_setting_income"
                            android:layout_marginEnd="12dp">

                            <ImageView
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_income"/>

                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvIncomeTitle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Set your income"
                                android:textColor="#EEF0FF"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                tools:text="Edit income"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Used to track savings &amp; budget"
                                android:textColor="#60B4B9DC"
                                android:textSize="11sp"
                                android:layout_marginTop="2dp"/>

                        </LinearLayout>

                    </LinearLayout>
                    <FrameLayout
                        android:id="@+id/btnClose"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="@drawable/bg_close_btn"
                        android:clickable="true"
                        android:focusable="true">

                        <View
                            android:layout_width="14dp"
                            android:layout_height="2dp"
                            android:layout_gravity="center"
                            android:rotation="45"
                            android:background="#80B4B9DC"/>

                        <View
                            android:layout_width="14dp"
                            android:layout_height="2dp"
                            android:layout_gravity="center"
                            android:rotation="-45"
                            android:background="#80B4B9DC"/>

                    </FrameLayout>

                </LinearLayout>
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_amount_box"
                    android:padding="24dp"
                    android:layout_marginBottom="24dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="MONTHLY INCOME"
                        android:textColor="#60B4B9DC"
                        android:textSize="10sp"
                        android:textAllCaps="true"
                        android:letterSpacing="0.05"
                        android:layout_marginBottom="10dp"/>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="₹"
                            android:textColor="#5DE8B8"
                            android:textSize="34sp"
                            android:textStyle="bold"
                            android:layout_marginEnd="4dp"/>
                        <EditText
                            android:id="@+id/etIncome"
                            android:layout_width="180dp"
                            android:layout_height="wrap_content"
                            android:background="@android:color/transparent"
                            android:hint="0"
                            android:textColorHint="#30B4B9DC"
                            android:textColor="#EEF0FF"
                            android:textSize="38sp"
                            android:textStyle="bold"
                            android:gravity="center"
                            android:inputType="numberDecimal"
                            android:singleLine="true"
                            android:imeOptions="actionDone"
                            android:maxLength="9"/>

                    </LinearLayout>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="per month"
                        android:textColor="#40B4B9DC"
                        android:textSize="11sp"
                        android:layout_marginTop="6dp"/>

                </LinearLayout>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="QUICK SELECT"
                    android:textColor="#60B4B9DC"
                    android:textSize="10sp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.05"
                    android:layout_marginBottom="10dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="24dp">

                    <TextView
                        android:id="@+id/chip25k"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="36dp"
                        android:gravity="center"
                        android:text="₹25K"
                        android:textColor="#A99DFF"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:background="@drawable/bg_quick_chip"
                        android:layout_marginEnd="8dp"
                        android:clickable="true"
                        android:focusable="true"/>

                    <TextView
                        android:id="@+id/chip50k"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="36dp"
                        android:gravity="center"
                        android:text="₹50K"
                        android:textColor="#A99DFF"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:background="@drawable/bg_quick_chip"
                        android:layout_marginEnd="8dp"
                        android:clickable="true"
                        android:focusable="true"/>

                    <TextView
                        android:id="@+id/chip75k"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="36dp"
                        android:gravity="center"
                        android:text="₹75K"
                        android:textColor="#A99DFF"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:background="@drawable/bg_quick_chip"
                        android:layout_marginEnd="8dp"
                        android:clickable="true"
                        android:focusable="true"/>

                    <TextView
                        android:id="@+id/chip1L"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="36dp"
                        android:gravity="center"
                        android:text="₹1L"
                        android:textColor="#A99DFF"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:background="@drawable/bg_quick_chip"
                        android:clickable="true"
                        android:focusable="true"/>

                </LinearLayout>

                <TextView
                    android:id="@+id/btnSaveIncome"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:gravity="center"
                    android:text="Save Income"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_btn_income"
                    android:clickable="true"
                    android:focusable="true"/>

                <!-- Error -->
                <TextView
                    android:id="@+id/tvIncomeError"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="#FF8A8A"
                    android:textSize="12sp"
                    android:gravity="center"
                    android:layout_marginTop="10dp"
                    android:visibility="gone"/>

            </LinearLayout>

    </FrameLayout>

</layout>