<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_bottom_sheet">


            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_dialog_glass"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="14dp"
                android:paddingBottom="32dp">

                <!-- Drag handle -->
                <View
                    android:layout_width="40dp"
                    android:layout_height="4dp"
                    android:background="@drawable/bg_drag_handle"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginBottom="20dp"/>

                <!-- Shimmer line -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@drawable/bg_shimmer_line"
                    android:layout_marginBottom="16dp"/>

                <!-- Title row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="20dp">

                    <!-- Icon + Title -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <!-- Category icon badge -->
                        <FrameLayout
                            android:id="@+id/ivCategoryIcon"
                            android:layout_width="42dp"
                            android:layout_height="42dp"
                            android:background="@drawable/bg_expense_icon_fuel"
                            android:layout_marginEnd="12dp">

                            <ImageView
                                android:id="@+id/imgCategoryIcon"
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_fuel"/>

                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <!-- Category label — set dynamically: binding.tvCategoryName.text = category -->
                            <TextView
                                android:id="@+id/tvCategoryName"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text=""
                                android:textColor="#EEF0FF"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                tools:text="Fuel"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Add expense"
                                android:textColor="#60B4B9DC"
                                android:textSize="12sp"
                                android:layout_marginTop="1dp"/>

                        </LinearLayout>

                    </LinearLayout>

                    <!-- Close button -->
                    <FrameLayout
                        android:id="@+id/btnClose"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="@drawable/bg_close_btn"
                        android:clickable="true"
                        android:focusable="true">

                        <View
                            android:layout_width="14dp"
                            android:layout_height="2dp"
                            android:layout_gravity="center"
                            android:rotation="45"
                            android:background="#80B4B9DC"/>

                        <View
                            android:layout_width="14dp"
                            android:layout_height="2dp"
                            android:layout_gravity="center"
                            android:rotation="-45"
                            android:background="#80B4B9DC"/>

                    </FrameLayout>

                </LinearLayout>

                <!-- ══ AMOUNT INPUT — large centered ══ -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_amount_box"
                    android:padding="20dp"
                    android:layout_marginBottom="18dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="AMOUNT"
                        android:textColor="#60B4B9DC"
                        android:textSize="10sp"
                        android:textAllCaps="true"
                        android:letterSpacing="0.05"
                        android:layout_marginBottom="8dp"/>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="₹"
                            android:textColor="#A99DFF"
                            android:textSize="32sp"
                            android:textStyle="bold"
                            android:layout_marginEnd="4dp"/>

                        <EditText
                            android:id="@+id/etAmount"
                            android:layout_width="160dp"
                            android:layout_height="wrap_content"
                            android:background="@android:color/transparent"
                            android:hint="0.00"
                            android:textColorHint="#30B4B9DC"
                            android:textColor="#EEF0FF"
                            android:textSize="36sp"
                            android:textStyle="bold"
                            android:gravity="center"
                            android:inputType="numberDecimal"
                            android:singleLine="true"
                            android:imeOptions="actionNext"
                            android:maxLength="8"/>

                    </LinearLayout>

                </LinearLayout>

                <!-- ══ DATE ══ -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DATE"
                    android:textColor="#60B4B9DC"
                    android:textSize="10sp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.05"
                    android:layout_marginBottom="6dp"/>

                <LinearLayout
                    android:id="@+id/layoutDatePicker"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:background="@drawable/bg_input_field"
                    android:layout_marginBottom="14dp"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_calendar"
                        android:layout_marginEnd="10dp"/>

                    <!-- Set dynamically: binding.tvSelectedDate.text = formatted date -->
                    <TextView
                        android:id="@+id/tvSelectedDate"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textColor="#EEF0FF"
                        android:textSize="13sp"
                        android:textColorHint="#40B4B9DC"
                        tools:text="09 Apr 2026"/>

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_chevron_down" />

                </LinearLayout>

                <!-- ══ NOTE ══ -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="NOTE  (optional)"
                    android:textColor="#60B4B9DC"
                    android:textSize="10sp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.05"
                    android:layout_marginBottom="6dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="90dp"
                    android:orientation="horizontal"
                    android:gravity="top"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp"
                    android:background="@drawable/bg_input_field"
                    android:layout_marginBottom="22dp">

                    <EditText
                        android:id="@+id/etNote"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@android:color/transparent"
                        android:hint="e.g. Full tank, 5L petrol..."
                        android:textColorHint="#40B4B9DC"
                        android:textColor="#EEF0FF"
                        android:textSize="13sp"
                        android:inputType="textMultiLine"
                        android:gravity="top"
                        android:imeOptions="actionDone"/>

                </LinearLayout>

                <!-- ══ SAVE BUTTON ══ -->
                <TextView
                    android:id="@+id/btnSaveExpense"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:gravity="center"
                    android:text="Save Expense"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_btn_primary"
                    android:clickable="true"
                    android:focusable="true"/>

                <!-- Error -->
                <TextView
                    android:id="@+id/tvExpenseError"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="#FF8A8A"
                    android:textSize="12sp"
                    android:gravity="center"
                    android:layout_marginTop="10dp"
                    android:visibility="gone"/>

            </LinearLayout>

    </FrameLayout>

</layout>