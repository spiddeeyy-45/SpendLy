<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="24dp"
    android:layout_marginEnd="24dp"
    android:layout_marginTop="20dp"
    app:cardCornerRadius="24dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="#1A1F35">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:background="@drawable/gradient_background_card">

        <!-- Label -->
        <TextView
            android:id="@+id/tvTotalLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Total this month"
            android:textColor="#6B7280"
            android:textSize="12sp" />

        <!-- Amount -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="6dp"
            android:gravity="top">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="₹"
                android:textColor="#6B7280"
                android:textSize="20sp"
                android:layout_marginTop="6dp" />

            <TextView
                android:id="@+id/tvTotalAmount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="#F0F2F7"
                android:textSize="36sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Chips -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="16dp"
            android:gravity="center_vertical">

            <!-- Growth -->
            <LinearLayout
                android:id="@+id/chipGrowth"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/chip_background"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"
                android:layout_marginEnd="8dp"
                android:gravity="center_vertical">

                <View
                    android:id="@+id/viewGrowthDot"
                    android:layout_width="6dp"
                    android:layout_height="6dp"
                    android:background="@drawable/bg_red_dot"
                    android:layout_marginEnd="6dp" />

                <TextView
                    android:id="@+id/tvGrowth"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="+0% vs last month"
                    android:textColor="#9CA3AF"
                    android:textSize="11sp" />
            </LinearLayout>

            <!-- Savings -->
            <LinearLayout
                android:id="@+id/chipSavings"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/chip_background"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"
                android:gravity="center_vertical">

                <View
                    android:id="@+id/viewSavingDot"
                    android:layout_width="6dp"
                    android:layout_height="6dp"
                    android:background="@drawable/bg_green_dot"
                    android:layout_marginEnd="6dp" />

                <TextView
                    android:id="@+id/tvSaving"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="₹0 saved"
                    android:textColor="#9CA3AF"
                    android:textSize="11sp" />
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>