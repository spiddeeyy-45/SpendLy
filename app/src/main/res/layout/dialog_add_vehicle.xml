<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_bottom_sheet">

        <!-- Glass overlay -->
        <eightbitlab.com.blurview.BlurView
            android:id="@+id/blurDialog"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_dialog_glass"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="14dp"
                android:paddingBottom="32dp">

                <!-- Drag handle -->
                <View
                    android:layout_width="40dp"
                    android:layout_height="4dp"
                    android:background="@drawable/bg_drag_handle"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginBottom="20dp"/>

                <!-- Shimmer line -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@drawable/bg_shimmer_line"
                    android:layout_marginBottom="16dp"/>

                <!-- Title row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="20dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Add Vehicle"
                            android:textColor="#EEF0FF"
                            android:textSize="20sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Fill in your vehicle details"
                            android:textColor="#60B4B9DC"
                            android:textSize="12sp"
                            android:layout_marginTop="2dp"/>

                    </LinearLayout>

                    <!-- Close button -->
                    <FrameLayout
                        android:id="@+id/btnClose"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="@drawable/bg_close_btn"
                        android:clickable="true"
                        android:focusable="true">

                        <View
                            android:layout_width="14dp"
                            android:layout_height="2dp"
                            android:layout_gravity="center"
                            android:rotation="45"
                            android:background="#80B4B9DC"/>

                        <View
                            android:layout_width="14dp"
                            android:layout_height="2dp"
                            android:layout_gravity="center"
                            android:rotation="-45"
                            android:background="#80B4B9DC"/>

                    </FrameLayout>

                </LinearLayout>

                <!-- ══ VEHICLE TYPE SELECTOR ══ -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="18dp">

                    <!-- BIKE -->
                    <LinearLayout
                        android:id="@+id/btnSelectBike"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:paddingTop="14dp"
                        android:paddingBottom="14dp"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/bg_vehicle_type_selected"
                        android:clickable="true"
                        android:focusable="true">

                        <ImageView
                            android:id="@+id/ivBikeIcon"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:src="@drawable/ic_bike"
                            android:layout_marginBottom="6dp"/>

                        <TextView
                            android:id="@+id/tvBikeLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Bike"
                            android:textColor="#A99DFF"
                            android:textSize="12sp"
                            android:textStyle="bold"/>

                    </LinearLayout>

                    <!-- CAR -->
                    <LinearLayout
                        android:id="@+id/btnSelectCar"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:paddingTop="14dp"
                        android:paddingBottom="14dp"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/bg_vehicle_default"
                        android:clickable="true"
                        android:focusable="true">

                        <ImageView
                            android:id="@+id/ivCarIcon"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:src="@drawable/ic_car"
                            android:layout_marginBottom="6dp"/>

                        <TextView
                            android:id="@+id/tvCarLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Car"
                            android:textColor="#80B4B9DC"
                            android:textSize="12sp"
                            android:textStyle="bold"/>

                    </LinearLayout>

                </LinearLayout>

                <!-- ══ COMPANY ══ -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="COMPANY / BRAND"
                    android:textColor="#60B4B9DC"
                    android:textSize="10sp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.05"
                    android:layout_marginBottom="6dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:background="@drawable/bg_input_field"
                    android:layout_marginBottom="14dp">

                    <EditText
                        android:id="@+id/etCompany"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@android:color/transparent"
                        android:hint="e.g. Hero, Honda, Bajaj"
                        android:textColor="#EEF0FF"
                        android:textSize="13sp"
                        android:inputType="textCapWords"
                        android:singleLine="true"
                        android:imeOptions="actionNext"/>

                </LinearLayout>

                <!-- ══ MODEL ══ -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MODEL NAME"
                    android:textColor="#60B4B9DC"
                    android:textSize="10sp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.05"
                    android:layout_marginBottom="6dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:background="@drawable/bg_input_field"
                    android:layout_marginBottom="14dp">

                    <EditText
                        android:id="@+id/etModel"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@android:color/transparent"
                        android:hint="e.g. Splendor, Activa, Swift"
                        android:textColor="#EEF0FF"
                        android:textSize="13sp"
                        android:inputType="textCapWords"
                        android:singleLine="true"
                        android:imeOptions="actionNext"/>

                </LinearLayout>

                <!-- ══ NUMBER PLATE ══ -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="NUMBER PLATE"
                    android:textColor="#60B4B9DC"
                    android:textSize="10sp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.05"
                    android:layout_marginBottom="6dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:background="@drawable/bg_input_field"
                    android:layout_marginBottom="14dp">

                    <EditText
                        android:id="@+id/etNumberPlate"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@android:color/transparent"
                        android:hint="MH 02 AB 1234"
                        android:textColor="#EEF0FF"
                        android:textSize="13sp"
                        android:inputType="textCapCharacters"
                        android:singleLine="true"
                        android:imeOptions="actionNext"/>

                </LinearLayout>

                <!-- ══ YEAR ══ -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="YEAR"
                    android:textColor="#60B4B9DC"
                    android:textSize="10sp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.05"
                    android:layout_marginBottom="6dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:background="@drawable/bg_input_field"
                    android:layout_marginBottom="22dp">

                    <EditText
                        android:id="@+id/etYear"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@android:color/transparent"
                        android:hint="e.g. 2022"
                        android:textColor="#EEF0FF"
                        android:textSize="13sp"
                        android:inputType="number"
                        android:maxLength="4"
                        android:singleLine="true"
                        android:imeOptions="actionDone"/>

                </LinearLayout>

                <!-- ══ ADD BUTTON ══ -->
                <TextView
                    android:id="@+id/btnAddVehicle"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:gravity="center"
                    android:text="Add Vehicle"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_btn_primary"
                    android:clickable="true"
                    android:focusable="true"/>

                <!-- Error -->
                <TextView
                    android:id="@+id/tvAddVehicleError"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="#FF8A8A"
                    android:textSize="12sp"
                    android:gravity="center"
                    android:layout_marginTop="10dp"
                    android:visibility="gone"/>

            </LinearLayout>

        </eightbitlab.com.blurview.BlurView>

    </FrameLayout>

</layout>