<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    tools:context="UI.ProfileFragment">
<FrameLayout
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#07071A">

    <!-- BG ORB 1 — top-left purple -->
    <View
        android:layout_width="300dp"
        android:layout_height="300dp"
        android:background="@drawable/bg_glow_orb_purp"
        android:alpha="0.35"
        android:layout_marginStart="-80dp"
        android:layout_marginTop="-60dp"/>

    <!-- BG ORB 2 — right blue -->
    <View
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:background="@drawable/bg_glow_orb_blue"
        android:alpha="0.2"
        android:layout_gravity="end"
        android:layout_marginEnd="-40dp"
        android:layout_marginTop="300dp"/>

    <!-- BG ORB 3 — bottom-left -->
    <View
        android:layout_width="240dp"
        android:layout_height="240dp"
        android:background="@drawable/bg_glow_orb_purp"
        android:alpha="0.22"
        android:layout_gravity="bottom|start"
        android:layout_marginBottom="100dp"
        android:layout_marginStart="20dp"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:scrollbars="none"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="52dp"
            android:paddingBottom="110dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Profile"
                android:textColor="#EEF0FF"
                android:textSize="26sp"
                android:textStyle="bold"
                android:layout_marginBottom="20dp"/>

            <!-- ══════════════════════════════ -->
            <!-- PROFILE CARD -->
            <!-- ══════════════════════════════ -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardProfile"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@android:color/transparent">


                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="28dp"
                        android:background="@drawable/bg_glass_card">

                        <ImageView
                            android:id="@+id/ivProfileImage"
                            android:layout_width="88dp"
                            android:layout_height="88dp"
                            android:clipToOutline="true"
                            android:background="@drawable/bg_avatar"
                            android:scaleType="centerCrop"
                            android:visibility="gone"
                            android:layout_marginBottom="14dp"
                            tools:visibility="gone"/>

                        <TextView
                            android:id="@+id/tvAvatar"
                            android:layout_width="88dp"
                            android:layout_height="88dp"
                            android:gravity="center"
                            android:text="🧑"
                            android:textSize="36sp"
                            android:background="@drawable/bg_avatar"
                            android:visibility="visible"
                            android:layout_marginBottom="14dp"/>

                        <TextView
                            android:id="@+id/tvProfileName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=""
                            android:textColor="#EEF0FF"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="4dp"
                            tools:text="Arbaz Shaikh"/>

                        <TextView
                            android:id="@+id/tvProfileSub"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=""
                            android:textColor="#8CB4B9DC"
                            android:textSize="12sp"
                            android:layout_marginBottom="16dp"
                            tools:text="Member since 2025 · Mumbai"/>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/tvBadgePlan"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text=""
                                android:textColor="#A99DFF"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                android:textAllCaps="true"
                                android:letterSpacing="0.05"
                                android:paddingStart="12dp"
                                android:paddingEnd="12dp"
                                android:paddingTop="4dp"
                                android:paddingBottom="4dp"
                                android:background="@drawable/bg_badge_purple"
                                android:layout_marginEnd="8dp"
                                tools:text="Premium"/>

                            <TextView
                                android:id="@+id/tvBadgeCity"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text=""
                                android:textColor="#80B4FF"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                android:textAllCaps="true"
                                android:letterSpacing="0.05"
                                android:paddingStart="12dp"
                                android:paddingEnd="12dp"
                                android:paddingTop="4dp"
                                android:paddingBottom="4dp"
                                android:background="@drawable/bg_badge_blue"
                                tools:text="Mumbai"/>

                        </LinearLayout>

                    </LinearLayout>

            </androidx.cardview.widget.CardView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="3"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="5dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_stats_card">

                    <TextView
                        android:id="@+id/tvTotalTracked"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textColor="#A99DFF"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        tools:text="₹2.3L"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Total tracked"
                        android:textColor="#80B4B9DC"
                        android:textSize="10sp"
                        android:gravity="center"
                        android:layout_marginTop="4dp"/>

                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_weight="1"
                    android:layout_marginStart="5dp"
                    android:layout_marginEnd="5dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_stats_card">

                    <TextView
                        android:id="@+id/tvSaved"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textColor="#5DE8B8"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        tools:text="₹18K"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Saved"
                        android:textColor="#80B4B9DC"
                        android:textSize="10sp"
                        android:layout_marginTop="4dp"/>

                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_weight="1"
                    android:layout_marginStart="5dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_stats_card">

                    <TextView
                        android:id="@+id/tvMonths"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textColor="#FBBF24"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        tools:text="3"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Months"
                        android:textColor="#80B4B9DC"
                        android:textSize="10sp"
                        android:layout_marginTop="4dp"/>

                </LinearLayout>

            </LinearLayout>

            <!-- ══════════════════════════════ -->
            <!-- MY VEHICLES -->
            <!-- ══════════════════════════════ -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="My Vehicles"
                android:textColor="#EEF0FF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="10dp"/>

            <androidx.cardview.widget.CardView
                android:id="@+id/cardVehicleSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@android:color/transparent">


                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="@drawable/bg_glass_card">

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="@drawable/bg_shimmer_line"/>

                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/rvVehicles"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:nestedScrollingEnabled="false"
                            android:overScrollMode="never"
                            tools:listitem="@layout/item_vehicle_add"
                            tools:itemCount="2"/>
                        <View
                            android:id="@+id/dividerVehicle"
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="#0DFFFFFF"
                            android:layout_marginStart="16dp"
                            android:layout_marginEnd="16dp"/>
                        <LinearLayout
                            android:id="@+id/btnAddVehicle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:padding="16dp"
                            android:clickable="true"
                            android:focusable="true"
                            android:background="?attr/selectableItemBackground">

                            <FrameLayout
                                android:layout_width="46dp"
                                android:layout_height="46dp"
                                android:background="@drawable/bg_add_vehicle_icon">

                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:gravity="center"
                                    android:text="+"
                                    android:textColor="#A99DFF"
                                    android:textSize="24sp"
                                    android:textStyle="bold"/>

                            </FrameLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_weight="1"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:layout_marginStart="14dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Add New Vehicle"
                                    android:textColor="#A99DFF"
                                    android:textSize="14sp"
                                    android:textStyle="bold"/>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Car, bike, or any vehicle"
                                    android:textColor="#60B4B9DC"
                                    android:textSize="11sp"
                                    android:layout_marginTop="2dp"/>

                            </LinearLayout>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="›"
                                android:textColor="#40A99DFF"
                                android:textSize="20sp"/>

                        </LinearLayout>
                    </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ══════════════════════════════ -->
            <!-- SETTINGS -->
            <!-- ══════════════════════════════ -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Settings"
                android:textColor="#EEF0FF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="10dp"/>

            <androidx.cardview.widget.CardView
                android:id="@+id/cardSettings"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@android:color/transparent">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="@drawable/bg_glass_card">

                        <!-- Shimmer line -->
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="@drawable/bg_shimmer_line"/>

                        <!-- Edit Profile -->
                        <LinearLayout
                            android:id="@+id/rowEditProfile"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:padding="15dp"
                            android:background="?attr/selectableItemBackground"
                            android:clickable="true"
                            android:focusable="true">

                            <FrameLayout
                                android:layout_width="38dp"
                                android:layout_height="38dp"
                                android:background="@drawable/bg_setting_default">
                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:gravity="center"
                                    android:text="👤"
                                    android:textSize="17sp"/>
                            </FrameLayout>

                            <TextView
                                android:layout_width="0dp"
                                android:layout_weight="1"
                                android:layout_height="wrap_content"
                                android:text="Edit Profile"
                                android:textColor="#EEF0FF"
                                android:textSize="14sp"
                                android:layout_marginStart="14dp"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="›"
                                android:textColor="#40B4B9DC"
                                android:textSize="18sp"/>

                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="#0DFFFFFF"/>

                        <!-- Notifications -->
                        <LinearLayout
                            android:id="@+id/rowIncome"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:padding="15dp"
                            android:background="?attr/selectableItemBackground"
                            android:clickable="true"
                            android:focusable="true">

                            <FrameLayout
                                android:layout_width="38dp"
                                android:layout_height="38dp"
                                android:background="@drawable/bg_setting_default">

                                <ImageView
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:src="@drawable/ic_income"/>
                            </FrameLayout>

                            <TextView
                                android:layout_width="0dp"
                                android:layout_weight="1"
                                android:layout_height="wrap_content"
                                android:text="Add Income"
                                android:textColor="#EEF0FF"
                                android:textSize="14sp"
                                android:layout_marginStart="14dp"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="›"
                                android:textColor="#40B4B9DC"
                                android:textSize="18sp"/>

                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="#0DFFFFFF"/>

                        <!-- Privacy -->
                        <LinearLayout
                            android:id="@+id/rowPrivacy"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:padding="15dp"
                            android:background="?attr/selectableItemBackground"
                            android:clickable="true"
                            android:focusable="true">

                            <FrameLayout
                                android:layout_width="38dp"
                                android:layout_height="38dp"
                                android:background="@drawable/bg_setting_default">
                                <ImageView
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:src="@drawable/ic_policy"/>
                            </FrameLayout>

                            <TextView
                                android:layout_width="0dp"
                                android:layout_weight="1"
                                android:layout_height="wrap_content"
                                android:text="Privacy Policy"
                                android:textColor="#EEF0FF"
                                android:textSize="14sp"
                                android:layout_marginStart="14dp"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="›"
                                android:textColor="#40B4B9DC"
                                android:textSize="18sp"/>

                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="#0DFFFFFF"/>

                        <!-- Logout -->
                        <LinearLayout
                            android:id="@+id/rowLogout"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:padding="15dp"
                            android:background="?attr/selectableItemBackground"
                            android:clickable="true"
                            android:focusable="true">

                            <FrameLayout
                                android:layout_width="38dp"
                                android:layout_height="38dp"
                                android:background="@drawable/bg_setting_logout">
                                <ImageView
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:src="@drawable/ic_logout"/>
                            </FrameLayout>

                            <TextView
                                android:layout_width="0dp"
                                android:layout_weight="1"
                                android:layout_height="wrap_content"
                                android:text="Logout"
                                android:textColor="#FF8A8A"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:layout_marginStart="14dp"/>

                        </LinearLayout>

                    </LinearLayout>

            </androidx.cardview.widget.CardView>

        </LinearLayout>

    </ScrollView>

</FrameLayout>
</layout>