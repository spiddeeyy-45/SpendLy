<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    tools:context=".HomeFragment">
<ScrollView
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="90dp">

        <!-- ===== HEADER ===== -->
        <include layout="@layout/layout_home_header" />

        <!-- ===== TOTAL CARD ===== -->
        <include layout="@layout/layout_total_spend" />

        <!-- ===== CATEGORY HEADER ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="20dp"
            android:paddingBottom="12dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="By Category"
                android:textColor="#F0F2F7"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="See all"
                android:textColor="#5B6EF5"
                android:textSize="12sp"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>

        <!-- ===== CATEGORY LIST ===== -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvCategories"
            android:layout_width="match_parent"
            android:layout_height="140dp"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:clipToPadding="false"
            android:overScrollMode="never"
            tools:listitem="@layout/item_category"/>

        <!-- ===== SPEND BREAKDOWN ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_surface2_round"
            android:padding="20dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Spend Breakdown"
                android:textColor="#F0F2F7"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="14dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <!-- Pie Chart -->
                <com.github.mikephil.charting.charts.PieChart
                    android:id="@+id/pieChart"
                    android:layout_width="110dp"
                    android:layout_height="110dp"
                    android:layout_marginEnd="20dp"/>


                <!-- Legend -->
                <LinearLayout
                    android:id="@+id/llLegend"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical" />
            </LinearLayout>
        </LinearLayout>

        <!-- ===== AI INSIGHT ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_ai_insight"
            android:padding="20dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✨ AI Insight"
                android:textColor="#A5B4FC"
                android:textSize="10sp"
                android:background="@drawable/bg_ai_insight"
                android:padding="6dp"
                android:layout_marginBottom="10dp" />

            <TextView
                android:id="@+id/tvAiInsight"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Loading insight..."
                android:textColor="#CBD5E1"
                android:textSize="13sp"
                android:lineSpacingMultiplier="1.6" />
        </LinearLayout>

        <!-- ===== RECENT HEADER ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="20dp"
            android:paddingBottom="12dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Recent"
                android:textColor="#F0F2F7"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="See all"
                android:textColor="#5B6EF5"
                android:textSize="12sp"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>

        <!-- ===== TRANSACTIONS LIST ===== -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvTransactions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:overScrollMode="never"
            tools:listitem="@layout/item_transaction"/>

    </LinearLayout>

</ScrollView>
    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/fabUploadPdf"
        android:layout_width="62dp"
        android:layout_height="62dp"
        android:layout_gravity="bottom|end"
        android:layout_marginBottom="50dp"
        android:layout_marginEnd="10dp"
        app:icon="@drawable/ic_ai_button"
        app:iconSize="28dp"
        app:iconTint="#FBBF24"
        app:backgroundTint="#18FFFFFF"
        app:elevation="12dp"
        app:cornerRadius="20dp"
        app:strokeColor="#30C4A882"
        app:strokeWidth="1dp"/>
</FrameLayout>