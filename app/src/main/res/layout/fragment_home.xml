<?xml version="1.0" encoding="utf-8"?>
<layout>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#07071A"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    tools:context="UI.HomeFragment">
    <!-- BG ORB 1 — top-left purple -->
    <View
        android:layout_width="300dp"
        android:layout_height="300dp"
        android:background="@drawable/bg_glow_orb_purp"
        android:alpha="0.35"
        android:layout_marginStart="-80dp"
        android:layout_marginTop="-60dp"/>

    <!-- BG ORB 2 — right blue -->
    <View
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:background="@drawable/bg_glow_orb_blue"
        android:alpha="0.2"
        android:layout_gravity="end"
        android:layout_marginEnd="-40dp"
        android:layout_marginTop="300dp"/>

    <!-- BG ORB 3 — bottom-left -->
    <View
        android:layout_width="240dp"
        android:layout_height="240dp"
        android:background="@drawable/bg_glow_orb_purp"
        android:alpha="0.22"
        android:layout_gravity="bottom|start"
        android:layout_marginBottom="100dp"
        android:layout_marginStart="20dp"/>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">
    <!-- ===== HEADER ===== -->
    <include
        android:id="@+id/headerLayout"
        layout="@layout/layout_home_header" />
<ScrollView
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="true"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">



        <!-- ===== TOTAL CARD ===== -->
        <include
            android:id="@+id/totalLayout"
            layout="@layout/layout_total_spend" />

        <!-- ===== CATEGORY HEADER ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="20dp"
            android:paddingBottom="12dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="By Category"
                android:textColor="#F0F2F7"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="See all"
                android:textColor="#5B6EF5"
                android:textSize="12sp"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>

        <!-- ===== CATEGORY LIST ===== -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvCategories"
            android:layout_width="match_parent"
            android:layout_height="140dp"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:clipToPadding="false"
            android:overScrollMode="never"
            tools:listitem="@layout/item_category"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_margin="20dp"
        android:background="@drawable/bg_glass_card">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Spend Breakdown"
            android:textColor="#EEF0FF"
            android:textSize="15sp"
            android:layout_marginTop="5dp"
            android:layout_marginLeft="10dp"
            android:textStyle="bold"
            android:layout_marginBottom="18dp"/>

        <!-- Donut + Legend row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Custom Donut View -->
            <FrameLayout
                android:layout_width="130dp"
                android:layout_height="130dp"
                android:layout_marginEnd="20dp">

                <Util.Home.DonutChartView
                    android:id="@+id/donutChart"
                    android:layout_width="110dp"
                    android:layout_height="110dp"
                    android:layout_marginLeft="10dp"
                    android:layout_marginBottom="20dp"/>

                <!-- Center label -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/tvDonutTotal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textColor="#EEF0FF"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        tools:text="0.0k"
                        xmlns:tools="http://schemas.android.com/tools"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="total"
                        android:textColor="#60B4B9DC"
                        android:textSize="9sp"/>

                </LinearLayout>

            </FrameLayout>
            <LinearLayout
                android:id="@+id/llLegend"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginRight="5dp"
                android:gravity="center_vertical"/>

        </LinearLayout>
    </LinearLayout>

        <!-- ===== AI INSIGHT ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_ai_insight"
            android:padding="20dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✨ AI Insight"
                android:textColor="#A5B4FC"
                android:textSize="10sp"
                android:background="@drawable/bg_ai_insight"
                android:padding="6dp"
                android:layout_marginBottom="10dp" />

            <TextView
                android:id="@+id/tvAiInsight"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Loading insight..."
                android:textColor="#CBD5E1"
                android:textSize="13sp"
                android:lineSpacingMultiplier="1.6" />
        </LinearLayout>

        <!-- ===== RECENT HEADER ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="20dp"
            android:paddingBottom="12dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Recent"
                android:textColor="#F0F2F7"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="See all"
                android:textColor="#5B6EF5"
                android:textSize="12sp"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>

        <!-- ===== TRANSACTIONS LIST ===== -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvTransactions"
            android:layout_width="match_parent"
            android:layout_height="210dp"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:overScrollMode="never"
            tools:listitem="@layout/item_transaction"/>

    </LinearLayout>

</ScrollView>
    </LinearLayout>
    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/fabUploadPdf"
        android:layout_width="62dp"
        android:layout_height="62dp"
        android:layout_gravity="bottom|end"
        android:layout_marginBottom="50dp"
        android:layout_marginEnd="10dp"
        app:icon="@drawable/ic_ai_button"
        app:iconSize="28dp"
        app:iconTint="#FBBF24"
        app:backgroundTint="#18FFFFFF"
        app:elevation="12dp"
        app:cornerRadius="20dp"
        app:strokeColor="#30C4A882"
        app:strokeWidth="1dp"/>
</FrameLayout>
</layout>