<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    tools:context="UI.AddFragment">
<FrameLayout
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#07071A">
    <!-- BG ORB 1 — top-left purple -->
    <View
        android:layout_width="300dp"
        android:layout_height="300dp"
        android:background="@drawable/bg_glow_orb_purp"
        android:alpha="0.35"
        android:layout_marginStart="-80dp"
        android:layout_marginTop="-60dp"/>

    <!-- BG ORB 2 — right blue -->
    <View
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:background="@drawable/bg_glow_orb_blue"
        android:alpha="0.2"
        android:layout_gravity="end"
        android:layout_marginEnd="-40dp"
        android:layout_marginTop="300dp"/>

    <!-- BG ORB 3 — bottom-left -->
    <View
        android:layout_width="240dp"
        android:layout_height="240dp"
        android:background="@drawable/bg_glow_orb_purp"
        android:alpha="0.22"
        android:layout_gravity="bottom|start"
        android:layout_marginBottom="100dp"
        android:layout_marginStart="20dp"/>
    <ScrollView
        android:id="@+id/scrollExpense"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:scrollbars="none"
        android:overScrollMode="never">

        <LinearLayout
            android:id="@+id/rootContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="110dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:paddingTop="52dp"
                android:paddingBottom="4dp">

                <TextView
                    android:id="@+id/tvExpenseTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/syne_bold"
                    android:letterSpacing="-0.02"
                    android:text="Add Expense"
                    android:textColor="#EEF0FF"
                    android:textSize="26sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvExpenseSubtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Log your daily spendings"
                    android:textColor="#80B4B9DC"
                    android:textSize="13sp"
                    android:layout_marginTop="3dp"/>

            </LinearLayout>

            <androidx.cardview.widget.CardView
                android:id="@+id/cardExpenseSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@android:color/transparent">
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_glass_card"
                        android:layout_gravity="center"/>
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">
                        <TextView
                            android:id="@+id/tvAddExpense"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Add Expense"
                            android:textColor="#EEF0FF"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/syne_bold"
                            android:layout_marginBottom="16dp"/>
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <include
                                android:id="@+id/cardFood"
                                layout="@layout/item_exp_food"/>
                            <include
                                android:id="@+id/cardGrocery"
                                layout="@layout/item_exp_grocery"/>
                            <include
                                android:id="@+id/cardTrip"
                                layout="@layout/item_exp_trip"/>

                        </LinearLayout>
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginTop="10dp">
                            <include
                                android:id="@+id/cardMedical"
                                layout="@layout/item_exp_medical"/>
                            <include
                                android:id="@+id/cardShopping"
                                layout="@layout/item_exp_shopping"/>
                            <include
                                android:id="@+id/cardSubscription"
                                layout="@layout/item_exp_subscription"/>
                        </LinearLayout>
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginTop="10dp">
                            <include
                                android:id="@+id/cardStocks"
                                layout="@layout/item_exp_stocks"/>
                            <include
                                android:id="@+id/cardOther"
                                layout="@layout/item_expense_others"/>
                        </LinearLayout>
                    </LinearLayout>
            </androidx.cardview.widget.CardView>
            <androidx.cardview.widget.CardView
                android:id="@+id/cardStatsSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="12dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@android:color/transparent">

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_glass_card"
                        android:layout_gravity="center"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:id="@+id/tvStatsTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="This Month"
                            android:textColor="#EEF0FF"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/syne_bold"
                            android:layout_marginBottom="14dp"/>

                        <!-- STATS ROW 1 -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <include
                                android:id="@+id/cardTotalSpend"
                                layout="@layout/item_statexp_total"/>

                            <include
                                android:id="@+id/cardGrocerySpend"
                                layout="@layout/item_stats_grocery"/>

                        </LinearLayout>

                        <!-- STATS ROW 2 -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginTop="10dp">

                            <include
                                android:id="@+id/cardShoppingSpend"
                                layout="@layout/item_stats_shopping"/>

                            <include
                                android:id="@+id/cardFoodSpend"
                                layout="@layout/item_stats_food"/>

                        </LinearLayout>

                    </LinearLayout>
            </androidx.cardview.widget.CardView>
            <androidx.cardview.widget.CardView
                android:id="@+id/cardChartSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="12dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@android:color/transparent">

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_glass_card"
                        android:layout_gravity="center"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="20dp">

                            <TextView
                                android:id="@+id/tvChartTitle"
                                android:layout_width="0dp"
                                android:layout_weight="1"
                                android:layout_height="wrap_content"
                                android:text="Expense Breakdown"
                                android:textColor="#EEF0FF"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                android:fontFamily="@font/syne_bold"/>

                            <!-- Toggle Monthly / Yearly -->
                            <TextView
                                android:id="@+id/togglebtn"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Monthly"
                                android:fontFamily="@font/syne_bold"
                                android:textColor="#A99DFF"
                                android:textSize="11sp"
                                android:paddingStart="12dp"
                                android:paddingEnd="12dp"
                                android:paddingTop="5dp"
                                android:paddingBottom="5dp"
                                android:background="@drawable/bg_toggle_pill"
                                android:clickable="true"
                                android:focusable="true"/>
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/chartContainer"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"/>
                    </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>

    </ScrollView>
</FrameLayout>
</layout>